---
import { aliases, facts, artist } from "../data/site";
---

<section id="story" class="snap relative mx-auto max-w-6xl px-6 py-24 sm:py-32">
  <div class="reveal mb-14 max-w-2xl">
    <p class="mb-3 text-xs tracking-[0.3em] text-[var(--color-cyan)] uppercase">
      Příběh
    </p>
    <h2
      class="font-[var(--font-display)] text-4xl font-extrabold tracking-tight text-balance sm:text-6xl"
    >
      Tři jména, <span class="text-gradient">jeden umělec</span>
    </h2>
    <p class="mt-5 text-white/65 sm:text-lg">
      {artist.realName} bere rap jako výtvarné médium. Jeho cesta vede od
      battle stagí přes restart kariéry až k syrovému, osobnímu undergroundu.
    </p>
  </div>

  <!-- Alias timeline -->
  <ol class="grid gap-5 md:grid-cols-3">
    {
      aliases.map((a, i) => (
        <li
          class="reveal glass glass-hover relative flex flex-col rounded-3xl p-7"
          style={`animation-delay:${i * 80}ms`}
        >
          <span class="font-[var(--font-display)] text-5xl font-extrabold text-white/10">
            0{i + 1}
          </span>
          <span class="mt-4 text-xs tracking-[0.25em] text-[var(--color-magenta)] uppercase">
            {a.era}
          </span>
          <h3 class="mt-1 font-[var(--font-display)] text-2xl font-bold">
            {a.name}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-white/60">{a.note}</p>
        </li>
      ))
    }
  </ol>

  <!-- Fact strip -->
  <dl
    class="reveal mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-3xl border border-white/10 bg-white/5 text-center lg:grid-cols-4"
  >
    {
      facts.map((f) => (
        <div class="bg-[var(--color-ink-2)]/60 px-4 py-7 backdrop-blur-md">
          <dt class="text-xs tracking-[0.2em] text-white/45 uppercase">
            {f.k}
          </dt>
          <dd class="mt-2 font-[var(--font-display)] text-lg font-bold text-white">
            {f.v}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
