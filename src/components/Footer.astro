---
import { artist, links } from "../data/site";
import Icon from "./Icon.astro";
const year = new Date().getFullYear();
---

<footer class="relative mx-auto max-w-6xl px-6 pb-12">
  <div
    class="glass flex flex-col items-center gap-6 rounded-3xl px-6 py-12 text-center"
  >
    <a
      href="#home"
      class="font-[var(--font-display)] text-3xl font-extrabold tracking-tight"
    >
      <span class="text-gradient">{artist.stageName}</span>
    </a>
    <p class="max-w-md text-sm text-white/55">
      {artist.realName} — {artist.genre} z Brna. Underground od {
        artist.activeSince
      }.
    </p>

    <ul class="flex flex-wrap items-center justify-center gap-3">
      {
        links.map((l) => (
          <li>
            <a
              href={l.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={l.label}
              class="inline-flex size-11 items-center justify-center rounded-full border border-white/12 text-white/70 transition-colors duration-300 hover:border-white/40 hover:text-white"
            >
              <Icon name={l.icon} class="size-5" />
            </a>
          </li>
        ))
      }
    </ul>

    <p class="text-xs text-white/35">
      © {year} {artist.realName}. Vyrobeno s láskou k undergroundu.
    </p>
  </div>
</footer>
